.gradle
**/build/
!src/**/build/

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Cache of project
.gradletasknamecache

# Eclipse Gradle plugin generated files
# Eclipse Core
.project
# JDT-specific (Eclipse Java Development Tools)
.classpath
.kotlin
build.bat
run.bat

/.vscode/
/run/
/.idea
/bin/

# Web server images directory (volume bind)
/web/images/*
!/web/images/.gitkeep

# Reference codebases
/references/*